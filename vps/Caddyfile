{
  email {$ACME_EMAIL}
}

# Redirect www to apex
www.example.com {
  redir https://example.com{uri}
}

# Deployed apps — Coolify's Traefik routes by domain on port 80
example.com {
  reverse_proxy {$COOLIFY_TAILSCALE_IP}:80 {
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Port {port}
    header_up X-Real-IP {remote_host}
  }
}

# Coolify dashboard
coolify.example.com {
  # Terminal WebSocket
  handle /terminal/ws* {
    reverse_proxy {$COOLIFY_TAILSCALE_IP}:6002
  }

  # Realtime WebSocket
  handle /app/* {
    reverse_proxy {$COOLIFY_TAILSCALE_IP}:6001
  }

  # Everything else
  handle {
    reverse_proxy {$COOLIFY_TAILSCALE_IP}:8000 {
      header_up X-Forwarded-Proto {scheme}
      header_up X-Forwarded-Port {port}
      header_up X-Real-IP {remote_host}
    }
  }
}
