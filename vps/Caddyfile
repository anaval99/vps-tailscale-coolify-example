}

# Redirect www to apex
www.{$APP1_DOMAIN} {
  redir https://{$APP1_DOMAIN}{uri}
}

# Deployed apps — Coolify's Traefik routes by domain on port 80
{$APP1_DOMAIN} {
  reverse_proxy {$COOLIFY_TAILSCALE_IP}:80 {
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Port {port}
    header_up X-Real-IP {remote_host}
  }
}

# Coolify dashboard
{$COOLIFY_DOMAIN} {
  reverse_proxy {$COOLIFY_TAILSCALE_IP}:8000 {
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Port {port}
    header_up X-Real-IP {remote_host}
  }
}