# Tailscale auth key — generate at https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-your-key-here

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=you@example.com

# Tailscale IP of the home server (find via: tailscale status)
COOLIFY_TAILSCALE_IP=100.x.x.x

# Domain for the Coolify dashboard
COOLIFY_DOMAIN=coolify.example.com

# Domains for deployed apps (Coolify's Traefik routes by domain)
APP1_DOMAIN=example.com
